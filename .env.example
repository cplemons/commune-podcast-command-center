# Commune Podcast Command Center — Environment Variables
# Copy this file to .env.local and fill in your actual values
# NOTE: Never commit .env.local to git — add it to .gitignore

# ─── YouTube Data API v3 ───────────────────────────────────────────
# Get from: https://console.cloud.google.com/apis/credentials
# Project: Podcast Dashboard (already enabled for @jeffkrasno)
YOUTUBE_API_KEY=your_youtube_api_key_here

# ─── Megaphone (Podcast Host) ─────────────────────────────────────
# Your Megaphone API token (from Megaphone CMS settings)
MEGAPHONE_API_TOKEN=your_megaphone_api_token_here
# Your Megaphone Network ID (from the CMS URL: cms.megaphone.fm/api/networks/NETWORK_ID)
MEGAPHONE_NETWORK_ID=your_megaphone_network_id_here

# ─── Anthropic (Claude AI Analysis Panel) ─────────────────────────
# Get from: https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ─── Apify (Social Media Scraping) ───────────────────────────────
# Get from: https://console.apify.com/account/integrations
# Used for: Instagram, Facebook, TikTok public data
APIFY_API_TOKEN=your_apify_token_here

# ─── Optional: App Settings ───────────────────────────────────────
# Set to 'true' to enable password protection
ENABLE_PASSWORD=false
DASHBOARD_PASSWORD=your_password_here
